    "Required to create Window Preview Card thumbnails. Images stay in memory and are never uploaded." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Required to create Window Preview Card thumbnails. Images stay in memory and are never uploaded." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "用于创建窗口预览卡片缩略图。图像仅保留在内存中，绝不会上传。" } } } },
