    "Quit and reopen PDock if Screen Recording does not become active immediately." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Quit and reopen PDock if Screen Recording does not become active immediately." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "如果屏幕录制权限未立即生效，请退出并重新打开 PDock。" } } } },
