    "PDock shows live previews of your Switchable Windows when you hover over a Previewable Application in the system Dock." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "PDock shows live previews of your Switchable Windows when you hover over a Previewable Application in the system Dock." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "当你将指针悬停在系统 Dock 的可预览应用上时，PDock 会显示所有可切换窗口的实时预览。" } } } },
